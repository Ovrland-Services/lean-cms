<% content_for :title, @magic_link.invitation? ? "Set Up Your Account" : "Reset Your Password" %>

<h1 class="font-bold text-2xl mb-2 text-gray-900">
  <%= @magic_link.invitation? ? "Set Up Your Account" : "Reset Your Password" %>
</h1>

<p class="text-gray-600 mb-6 text-sm">
  <% if @magic_link.invitation? %>
    Welcome, <%= @user.display_name %>! Please create a password for your account.
  <% else %>
    Enter your new password below.
  <% end %>
</p>

<%= form_with url: lean_cms_password_setup_path(token: @magic_link.token), method: :patch, class: "space-y-5" do |form| %>
  <div>
    <%= form.label :password, "New Password", class: "block text-sm font-semibold text-gray-700 mb-2" %>
    <%= form.password_field :password, required: true, autofocus: true, autocomplete: "new-password", placeholder: "Enter new password (minimum 8 characters)", minlength: 8, class: "lc-focus w-full px-4 py-3 border-2 border-gray-300 rounded-lg outline-none transition-colors" %>
  </div>

  <div>
    <%= form.label :password_confirmation, "Confirm Password", class: "block text-sm font-semibold text-gray-700 mb-2" %>
    <%= form.password_field :password_confirmation, required: true, autocomplete: "new-password", placeholder: "Confirm your password", minlength: 8, class: "lc-focus w-full px-4 py-3 border-2 border-gray-300 rounded-lg outline-none transition-colors" %>
  </div>

  <%= form.submit "Set Password", class: "lc-btn-primary w-full px-6 py-3 text-white font-semibold rounded-lg shadow-sm cursor-pointer transition" %>
<% end %>
